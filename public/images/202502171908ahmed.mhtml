.UIStandardFrame_Container { margin: 0px auto; padding-top: 20px; width: 96=
0px; }

.UIStandardFrame_Content { float: left; margin: 0px; padding: 0px; width: 7=
60px; }

.UIStandardFrame_SidebarAds { float: right; margin: 0px; padding: 0px; widt=
h: 200px; overflow-wrap: break-word; }

.UIFullPage_Container { margin: 0px auto; padding: 20px 12px 0px; width: 94=
0px; }

.empty_message { background: rgb(245, 246, 247); font-size: 13px; line-heig=
ht: 17px; padding: 20px 20px 50px; text-align: center; }

.see_all { text-align: right; }

.standard_status_element { visibility: hidden; }

.standard_status_element.async_saving { visibility: visible; }

